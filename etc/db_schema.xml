<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/db_schema.xsd">
    
    <table name="aprilo_chatbot_session" resource="default" engine="innodb" comment="Chatbot Session Management">
        <column name="session_id" xsi:type="int" unsigned="true" nullable="false" identity="true" comment="Session ID"/>
        <column name="user_id" xsi:type="int" unsigned="true" nullable="true" comment="Magento User ID"/>
        <column name="token" xsi:type="text" nullable="false" comment="Session Token"/>
        <column name="logged_in" xsi:type="boolean" nullable="false" default="0" comment="Is User Logged In?"/>
        <column name="created_at" xsi:type="timestamp" nullable="false" default="CURRENT_TIMESTAMP" comment="Session Start Time"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="session_id"/>
        </constraint>
    </table>
</schema>
